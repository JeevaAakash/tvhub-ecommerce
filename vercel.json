{
  "version": 2,
  "buildCommand": "echo 'Frontend static files'",
  "outputDirectory": ".",
  "framework": "static",
  "public": true,
  "env": {
    "REACT_APP_API_URL": {
      "description": "Backend API URL"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
